<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.NotificationsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="◀" FontSize="16" BackgroundColor="Transparent"
                    TextColor="White" Padding="4,0" HeightRequest="34" WidthRequest="40"
                    Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="🔔 Notifications" TextColor="White"
                   FontSize="15" FontAttributes="Bold"
                   VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="14,16,14,24">

                <!-- App Notifications Card -->
                <Frame BackgroundColor="White" CornerRadius="12" BorderColor="#E5E7EB"
                       Padding="16,12" HasShadow="False">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="APP NOTIFICATIONS" FontSize="11" FontAttributes="Bold"
                               TextColor="#6B7280" Margin="0,0,0,10"/>

                        <!-- Permission banner -->
                        <Frame x:Name="permBanner" IsVisible="False"
                               BackgroundColor="#FEF3C7" CornerRadius="8"
                               BorderColor="#F59E0B" Padding="10,8" Margin="0,0,0,6">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="PermBanner_Tapped"/>
                            </Frame.GestureRecognizers>
                            <Label Text="⚠ Notifications are BLOCKED. Tap here to open Settings."
                                   FontSize="12" TextColor="#92400E" HorizontalTextAlignment="Center"/>
                        </Frame>

                        <!-- Enable toggle -->
                        <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                            <Label Grid.Column="0" Text="Enable Notifications"
                                   FontSize="15" TextColor="#1F2937" VerticalOptions="Center"/>
                            <Switch Grid.Column="1" x:Name="switchEnabled"
                                    OnColor="#1E3A8A" ThumbColor="White"
                                    Toggled="SwitchEnabled_Toggled"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,2"/>

                        <!-- Days ahead -->
                        <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="Alert Days Ahead" FontSize="15" TextColor="#1F2937"/>
                                <Label Text="Notify when tickets expire within this many days"
                                       FontSize="11" TextColor="#9CA3AF"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" x:Name="btnDaysAhead"
                                    FontSize="14" FontAttributes="Bold"
                                    TextColor="#1E3A8A" BackgroundColor="#EFF6FF"
                                    CornerRadius="8" WidthRequest="56" HeightRequest="36"
                                    Clicked="BtnDaysAhead_Clicked"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,2"/>

                        <!-- Notification Times -->
                        <VerticalStackLayout Spacing="4" Padding="0,10,0,4">
                            <Label Text="Notification Times" FontSize="15" TextColor="#1F2937"/>
                            <Label Text="Tap times to add/remove — alerts fire at each selected time"
                                   FontSize="11" TextColor="#9CA3AF"/>
                            <FlexLayout x:Name="timesChips" Wrap="Wrap" Direction="Row"
                                        JustifyContent="Start" Margin="0,6,0,0"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#F3F4F6" Margin="0,2"/>

                        <!-- Test button -->
                        <Button Text="Send Test Notification" FontSize="13" FontAttributes="Bold"
                                BackgroundColor="#1E3A8A" TextColor="White"
                                CornerRadius="8" HeightRequest="38" Margin="0,10,0,2"
                                Clicked="BtnTestNotif_Clicked"/>

                    </VerticalStackLayout>
                </Frame>

                <!-- Status label -->
                <Label x:Name="lblStatus" Text="" FontSize="12"
                       TextColor="#6B7280" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" Margin="0,4"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
