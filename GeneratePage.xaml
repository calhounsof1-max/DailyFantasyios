<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.GeneratePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D1117"
             ios:Page.UseSafeArea="false">

    <Grid RowDefinitions="Auto,*,Auto" x:Name="rootGrid">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6"
              ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Text="←" FontSize="12" TextColor="White"
                    BackgroundColor="Transparent" Padding="4,0"
                    HeightRequest="28" MinimumWidthRequest="28"
                    Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="Generate Numbers"
                   TextColor="White" FontSize="13" FontAttributes="Bold"
                   VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10,10" Spacing="10">

                <!-- Game selector -->
                <Label Text="SELECT GAME" FontSize="9" FontAttributes="Bold"
                       TextColor="#9CA3AF" CharacterSpacing="1.5"
                       HorizontalOptions="Center"/>
                <HorizontalStackLayout x:Name="stkGames" Spacing="5"
                                       HorizontalOptions="Center"/>

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#1E2733"/>

                <!-- Count control -->
                <Grid ColumnDefinitions="*,36,44,36,*" ColumnSpacing="4"
                      HorizontalOptions="Center">
                    <Label Grid.Column="0" Text="Generate" FontSize="12"
                           TextColor="#D1D5DB" VerticalOptions="Center"
                           HorizontalOptions="End"/>
                    <Button Grid.Column="1" Text="−" FontSize="14" FontAttributes="Bold"
                            BackgroundColor="#2D3D50" TextColor="White"
                            HeightRequest="32" CornerRadius="16" Padding="0"
                            Clicked="BtnMinus_Clicked"/>
                    <Label Grid.Column="2" x:Name="lblCount" Text="5"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White" HorizontalTextAlignment="Center"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="3" Text="+" FontSize="14" FontAttributes="Bold"
                            BackgroundColor="#2D3D50" TextColor="White"
                            HeightRequest="32" CornerRadius="16" Padding="0"
                            Clicked="BtnPlus_Clicked"/>
                    <Label Grid.Column="4" Text="rows" FontSize="12"
                           TextColor="#D1D5DB" VerticalOptions="Center"/>
                </Grid>

                <!-- Generate button -->
                <Button x:Name="btnGenerate" Text="⚡  GENERATE"
                        FontSize="12" FontAttributes="Bold"
                        BackgroundColor="#FF8F00" TextColor="White"
                        HeightRequest="38" CornerRadius="19"
                        Clicked="BtnGenerate_Clicked"/>

                <!-- Activity + status -->
                <ActivityIndicator x:Name="spinner" IsRunning="False" IsVisible="False"
                                   Color="#FF8F00" HorizontalOptions="Center"
                                   WidthRequest="24" HeightRequest="24"/>
                <Label x:Name="lblStatus" Text="" FontSize="10"
                       TextColor="#8B9DC3" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <!-- Results -->
                <VerticalStackLayout x:Name="resultsStack" Spacing="3"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Save bar (shown after generating) -->
        <Grid Grid.Row="2" x:Name="saveBar" BackgroundColor="#1E2733"
              Padding="10,7" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6"
              IsVisible="False">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="SAVE TO SET" FontSize="9" FontAttributes="Bold"
                       TextColor="#9CA3AF" CharacterSpacing="1"/>
                <Picker x:Name="pickerSet" Title="Choose set…"
                        FontSize="10" TextColor="White" TitleColor="#6B7280"/>
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="🗑 Clear"
                    FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#7B1111" TextColor="White"
                    HeightRequest="40" WidthRequest="60" CornerRadius="8"
                    VerticalOptions="End"
                    Clicked="BtnClearAll_Clicked"/>
            <Button Grid.Column="2" Text="Save ↗"
                    FontSize="10" FontAttributes="Bold"
                    BackgroundColor="#2E7D32" TextColor="White"
                    HeightRequest="40" WidthRequest="70" CornerRadius="8"
                    VerticalOptions="End"
                    Clicked="BtnSave_Clicked"/>
        </Grid>

        <!-- Edit row overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="editOverlay"
              BackgroundColor="#C0000000" IsVisible="False">
            <Border BackgroundColor="#1E2733" Padding="16"
                    VerticalOptions="Center" HorizontalOptions="Fill"
                    Margin="14,0" StrokeThickness="0"
                    StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="editRowTitle" Text="Edit Row"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>
                    <HorizontalStackLayout x:Name="editEntryRow" Spacing="5"
                                           HorizontalOptions="Center"/>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,3,0,0">
                        <Button Grid.Column="0" Text="Cancel"
                                BackgroundColor="#37474F" TextColor="White"
                                CornerRadius="16" HeightRequest="34"
                                FontSize="9"
                                Clicked="BtnEditRowCancel_Clicked"/>
                        <Button Grid.Column="1" Text="Apply"
                                BackgroundColor="#2E7D32" TextColor="White"
                                CornerRadius="16" HeightRequest="34"
                                FontSize="9"
                                Clicked="BtnEditRowApply_Clicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
