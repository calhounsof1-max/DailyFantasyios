<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.DataViewerPage"
             Title="Data Viewer"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E2733"
             ios:Page.UseSafeArea="false">

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="← BACK" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White"
                    Padding="6,0" HeightRequest="28" CornerRadius="14"
                    Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" x:Name="lblTitle" Text="Data Viewer" TextColor="White"
                   FontSize="14" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- File picker -->
        <Grid Grid.Row="1" Padding="10,5" ColumnDefinitions="*,Auto" ColumnSpacing="6"
              BackgroundColor="White">
            <Picker x:Name="filePicker" Grid.Column="0"
                    Title="Select file..." FontSize="11"
                    SelectedIndexChanged="FilePicker_SelectedIndexChanged"/>
            <Label Grid.Column="1" x:Name="lblLineCount"
                   FontSize="10" TextColor="#9CA3AF" VerticalOptions="Center"/>
        </Grid>

        <!-- Date filter -->
        <Grid Grid.Row="2" Padding="10,4" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6"
              BackgroundColor="#EEF2F7">
            <Label Grid.Column="0" Text="Month/Day:" FontSize="10" TextColor="#546E7A"
                   VerticalOptions="Center"/>
            <DatePicker x:Name="datePicker" Grid.Column="1" FontSize="10"
                        Format="yyyy-MM-dd" VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="Filter" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#1565C0" TextColor="White"
                    HeightRequest="24" Padding="8,0" CornerRadius="12"
                    Clicked="BtnFilter_Clicked"/>
            <Button Grid.Column="3" Text="All" FontSize="9"
                    BackgroundColor="#78909C" TextColor="White"
                    HeightRequest="24" Padding="8,0" CornerRadius="12"
                    Clicked="BtnShowAll_Clicked"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <CollectionView x:Name="lineList" Grid.Column="0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding .}"
                               FontFamily="Monospace"
                               FontSize="11"
                               TextColor="#1E2A3A"
                               Padding="10,2"
                               LineBreakMode="NoWrap"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <!-- Jump buttons -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6" Padding="3">
                <Button Text="▲" FontSize="12" WidthRequest="32" HeightRequest="32"
                        CornerRadius="16" BackgroundColor="#1565C0" TextColor="White"
                        Clicked="BtnTop_Clicked"/>
                <Button Text="▼" FontSize="12" WidthRequest="32" HeightRequest="32"
                        CornerRadius="16" BackgroundColor="#1565C0" TextColor="White"
                        Clicked="BtnBottom_Clicked"/>
            </VerticalStackLayout>
            <VerticalStackLayout x:Name="loadingPanel" IsVisible="False"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                <ActivityIndicator x:Name="spinner" IsRunning="False" Color="#1E2733"
                                   WidthRequest="30" HeightRequest="30"/>
                <Label Text="Loading..." FontSize="11" TextColor="#546E7A"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
