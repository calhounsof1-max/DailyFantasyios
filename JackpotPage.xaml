<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.JackpotPage"
             Title="Jackpot Winners"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E2733"
             ios:Page.UseSafeArea="true">

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,*,Auto">
        <Grid.GestureRecognizers>
            <PanGestureRecognizer PanUpdated="OnPagePan"/>
        </Grid.GestureRecognizers>

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="◀" FontSize="12" BackgroundColor="Transparent"
                    TextColor="White" Padding="3,0" HeightRequest="28" WidthRequest="32"
                    Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="Jackpot Winners" TextColor="White"
                   FontSize="13" FontAttributes="Bold" VerticalOptions="Center"
                   HorizontalOptions="Center"/>
            <Button Grid.Column="2" Text="↕" FontSize="12" BackgroundColor="Transparent"
                    TextColor="#8B9DC3" Padding="3,0" HeightRequest="28" WidthRequest="28"
                    Clicked="BtnSort_Clicked"/>
            <Button Grid.Column="3" Text="Refresh" FontSize="9" BackgroundColor="#2D3D50"
                    TextColor="White" Padding="6,0" HeightRequest="28" CornerRadius="14"
                    Clicked="BtnRefresh_Clicked"/>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" x:Name="progressBar" Progress="0"
                     ProgressColor="#FF8F00" BackgroundColor="#2D3D50"
                     HeightRequest="3" IsVisible="False"/>

        <!-- Cards -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="cardsStack" Spacing="8" Padding="10,10,10,10">

                <Label x:Name="lblLastChecked" Text="" HorizontalOptions="Center"
                       FontSize="9" TextColor="#9CA3AF"/>

                <!-- Fantasy 5 -->
                <Frame x:Name="cardF5" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="F5"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Fantasy 5" FontSize="12"
                                   FontAttributes="Bold" TextColor="#FF8F00"/>
                            <Label Grid.Column="1" x:Name="lblF5Badge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblF5Date" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblF5Numbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblF5Result" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblF5Jackpot" Text="" FontSize="11" FontAttributes="Bold" TextColor="#FF8F00"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Super Lotto Plus -->
                <Frame x:Name="cardSL" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="SL"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Super Lotto Plus" FontSize="12"
                                   FontAttributes="Bold" TextColor="#7B1FA2"/>
                            <Label Grid.Column="1" x:Name="lblSLBadge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblSLDate" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblSLNumbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblSLResult" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblSLJackpot" Text="" FontSize="11" FontAttributes="Bold" TextColor="#7B1FA2"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Powerball -->
                <Frame x:Name="cardPB" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="PB"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Powerball" FontSize="12"
                                   FontAttributes="Bold" TextColor="#C62828"/>
                            <Label Grid.Column="1" x:Name="lblPBBadge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblPBDate" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblPBNumbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblPBResult" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblPBJackpot" Text="" FontSize="11" FontAttributes="Bold" TextColor="#C62828"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Mega Millions -->
                <Frame x:Name="cardMM" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="MM"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Mega Millions" FontSize="12"
                                   FontAttributes="Bold" TextColor="#1565C0"/>
                            <Label Grid.Column="1" x:Name="lblMMBadge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblMMDate" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblMMNumbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblMMResult" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblMMJackpot" Text="" FontSize="11" FontAttributes="Bold" TextColor="#1565C0"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Daily Derby -->
                <Frame x:Name="cardDD" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="DD"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Daily Derby" FontSize="12"
                                   FontAttributes="Bold" TextColor="#5D4037"/>
                            <Label Grid.Column="1" x:Name="lblDDBadge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblDDDate" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblDDNumbers" Text="" FontFamily="Monospace"
                               FontSize="12" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblDDResult" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblDDJackpot" Text="" FontSize="11" FontAttributes="Bold" TextColor="#5D4037"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Daily 4 -->
                <Frame x:Name="cardD4" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="D4"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Daily 4" FontSize="12"
                                   FontAttributes="Bold" TextColor="#00695C"/>
                            <Label Grid.Column="1" x:Name="lblD4Badge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblD4Date" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblD4Numbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblD4Result" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Daily 3 -->
                <Frame x:Name="cardD3" BackgroundColor="White" CornerRadius="10"
                       BorderColor="#E5E7EB" Padding="10,8" HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCardTapped" CommandParameter="D3"/>
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="3">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Daily 3" FontSize="12"
                                   FontAttributes="Bold" TextColor="#1976D2"/>
                            <Label Grid.Column="1" x:Name="lblD3Badge" Text=""
                                   FontSize="9" FontAttributes="Bold"
                                   TextColor="White" BackgroundColor="#9CA3AF"
                                   Padding="5,2" VerticalOptions="Center"/>
                        </Grid>
                        <Label x:Name="lblD3Date" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label x:Name="lblD3Numbers" Text="" FontFamily="Monospace"
                               FontSize="14" FontAttributes="Bold" TextColor="#1E2733"/>
                        <Label x:Name="lblD3Result" Text="" FontSize="10" TextColor="#6B7280"/>
                        <Label Text="Tap to see payout details ▶" FontSize="9" TextColor="#9CA3AF" HorizontalOptions="End"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Status bar -->
        <Label Grid.Row="3" x:Name="lblStatus" Text="Loading..."
               BackgroundColor="#1E2733" TextColor="#8B9DC3"
               FontSize="9" Padding="10,3" LineBreakMode="TailTruncation"/>

        <!-- Full-page Draw Results overlay -->
        <Grid x:Name="overlayGrid" Grid.Row="0" Grid.RowSpan="4"
              BackgroundColor="White" IsVisible="False">
            <Grid RowDefinitions="Auto,*">

                <!-- Colored header -->
                <Grid Grid.Row="0" x:Name="overlayHeader" BackgroundColor="#FF8F00" Padding="6,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Text="←" FontSize="14" BackgroundColor="Transparent"
                            TextColor="White" WidthRequest="36" HeightRequest="32"
                            Clicked="BtnCloseOverlay_Clicked"/>
                    <Label Grid.Column="1" Text="Draw Results" TextColor="White"
                           FontSize="13" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <!-- Scrollable detail content -->
                <ScrollView Grid.Row="1" BackgroundColor="#F0F4F8">
                    <VerticalStackLayout Spacing="0" Padding="0,0,0,20">

                        <!-- White detail card -->
                        <Frame Margin="10,10,10,0" BackgroundColor="White"
                               CornerRadius="10" BorderColor="#E5E7EB"
                               Padding="12,12" HasShadow="False">
                            <VerticalStackLayout Spacing="0">

                                <!-- Game name -->
                                <Label x:Name="overlayGameName" Text=""
                                       FontSize="16" FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       Margin="0,0,0,12"/>

                                <!-- DRAW section -->
                                <Label Text="DRAW" FontSize="10" FontAttributes="Bold"
                                       TextColor="#00A0DC" Margin="0,0,0,3"/>
                                <BoxView HeightRequest="1" Color="#00A0DC" Margin="0,0,0,8"/>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                    <Label Grid.Column="0" x:Name="overlayDrawDate"
                                           Text="" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1E2733" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="▼" TextColor="#9CA3AF"
                                           FontSize="11" VerticalOptions="Center"/>
                                </Grid>

                                <!-- WINNING NUMBERS section -->
                                <Label Text="WINNING NUMBERS" FontSize="10" FontAttributes="Bold"
                                       TextColor="#00A0DC" Margin="0,0,0,3"/>
                                <BoxView HeightRequest="1" Color="#00A0DC" Margin="0,0,0,8"/>

                                <!-- Number balls (added dynamically) -->
                                <FlexLayout x:Name="overlayNumbersPanel"
                                            Wrap="Wrap" JustifyContent="Center"
                                            AlignItems="Center" Direction="Row"
                                            Margin="0,0,0,6"/>

                                <!-- Race time for Daily Derby -->
                                <Label x:Name="overlayRaceTime" Text="" IsVisible="False"
                                       FontSize="11" TextColor="#6B7280"
                                       HorizontalOptions="Center" Margin="0,0,0,10"/>

                                <!-- PRIZES section -->
                                <Label Text="PRIZES" FontSize="10" FontAttributes="Bold"
                                       TextColor="#00A0DC" Margin="0,6,0,3"/>
                                <BoxView HeightRequest="1" Color="#00A0DC" Margin="0,0,0,0"/>

                                <!-- Prize rows (added dynamically) -->
                                <VerticalStackLayout x:Name="overlayPrizesPanel" Spacing="0"/>

                            </VerticalStackLayout>
                        </Frame>

                        <!-- Close button at bottom -->
                        <Button Text="Close" Margin="20,14,20,0"
                                BackgroundColor="#1E2733" TextColor="White"
                                FontSize="12" HeightRequest="38" CornerRadius="19"
                                Clicked="BtnCloseOverlay_Clicked"/>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>
        </Grid>

        <!-- Reorder overlay -->
        <Grid x:Name="reorderOverlay" Grid.Row="0" Grid.RowSpan="4"
              BackgroundColor="White" IsVisible="False">
            <Grid RowDefinitions="Auto,*,Auto">

                <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="44"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Text="←" FontSize="14" BackgroundColor="Transparent"
                            TextColor="White" WidthRequest="36" HeightRequest="32"
                            Clicked="BtnReorderCancel_Clicked"/>
                    <Label Grid.Column="1" Text="Arrange Games" TextColor="White"
                           FontSize="13" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>

                <ScrollView Grid.Row="1" BackgroundColor="#F0F4F8">
                    <VerticalStackLayout x:Name="reorderStack" Spacing="6" Padding="10,12"/>
                </ScrollView>

                <Button Grid.Row="2" Text="Save Order" BackgroundColor="#1E2733"
                        TextColor="White" FontSize="12" HeightRequest="40"
                        CornerRadius="20" Margin="20,10,20,14"
                        Clicked="BtnReorderDone_Clicked"/>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>
