<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.MyFavoritePage"
             Title="My Favorites"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E2733"
             ios:Page.UseSafeArea="true">

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6"
              ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" Text="← Back" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="My Favorites" TextColor="White" FontSize="13"
                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" x:Name="btnCollapseAll" Text="⊟" FontSize="11"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Margin="0,0,4,0"
                    Clicked="BtnCollapseAll_Clicked"/>
            <Button Grid.Column="3" Text="+ New" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2E7D32" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnNew_Clicked"/>
        </Grid>

        <!-- Row 1: File + Set pickers -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="White" Padding="10,6" Spacing="4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0" Text="File:" FontSize="11" FontAttributes="Bold"
                       TextColor="#374151" VerticalOptions="Center" Margin="0,0,6,0"/>
                <Picker Grid.Column="1" x:Name="filePicker" FontSize="10"
                        BackgroundColor="#F8F9FA" HeightRequest="22"
                        SelectedIndexChanged="FilePicker_Changed"/>
                <Button Grid.Column="2" x:Name="btnDelete" Text="🗑" FontSize="11"
                        BackgroundColor="#B71C1C" TextColor="White" Padding="5,0"
                        HeightRequest="22" CornerRadius="6" Margin="4,0,0,0"
                        Clicked="BtnDelete_Clicked"/>
            </Grid>
            <Grid ColumnDefinitions="Auto,*" x:Name="setPickerRow">
                <Label Grid.Column="0" Text="Set:" FontSize="11" FontAttributes="Bold"
                       TextColor="#374151" VerticalOptions="Center" Margin="0,0,6,0"/>
                <Picker Grid.Column="1" x:Name="setPicker" FontSize="10"
                        BackgroundColor="#F8F9FA" HeightRequest="22"
                        SelectedIndexChanged="SetPicker_Changed"/>
            </Grid>
            <Label x:Name="lblGameInfo" Text="" FontSize="10" TextColor="#6B7A90"/>
        </VerticalStackLayout>

        <!-- Row 2: No files message -->
        <Label Grid.Row="2" x:Name="lblNoFiles"
               Text="No saved favorites yet.&#10;Use More → Export Sets → Save to MyFavorite to create one."
               FontSize="11" TextColor="#9CA3AF" HorizontalOptions="Center"
               HorizontalTextAlignment="Center" Margin="16,16" IsVisible="False"/>

        <!-- Row 3: Entry grid -->
        <ScrollView Grid.Row="3" BackgroundColor="#F0F4F8">
            <VerticalStackLayout x:Name="rowsContainer" Padding="8,6" Spacing="4"/>
        </ScrollView>

        <!-- Row 4: Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,*" ColumnSpacing="4"
              Padding="8,5" BackgroundColor="#1E2733" x:Name="btnRow">
            <Button Grid.Column="0" Text="SAVE FILE" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2E7D32" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnSaveFile_Clicked"/>
            <Button Grid.Column="1" Text="LOAD TO GAME" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#1565C0" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnLoadToGame_Clicked"/>
            <Button Grid.Column="2" Text="CLEAR ROWS" FontSize="9"
                    BackgroundColor="#FF7043" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnClearRows_Clicked"/>
        </Grid>

    </Grid>
</ContentPage>
