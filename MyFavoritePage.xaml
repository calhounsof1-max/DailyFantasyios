<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.MyFavoritePage"
             Title="My Favorites"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E2733">

    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="iOS" Value="0,0,0,34"/>
        </OnPlatform>
    </ContentPage.Padding>

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="14,10"
              ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" Text="← Back" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="My Favorites" TextColor="White" FontSize="14"
                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" x:Name="btnCollapseAll" Text="⊟" FontSize="14"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Margin="0,0,6,0"
                    Clicked="BtnCollapseAll_Clicked"/>
            <Button Grid.Column="3" Text="+ New" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#2E7D32" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnNew_Clicked"/>
        </Grid>

        <!-- Row 1: File + Set pickers -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="White" Padding="12,8" Spacing="6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0" Text="File:" FontSize="13" FontAttributes="Bold"
                       TextColor="#374151" VerticalOptions="Center" Margin="0,0,8,0"/>
                <Picker Grid.Column="1" x:Name="filePicker" FontSize="13"
                        BackgroundColor="#F8F9FA" HeightRequest="36"
                        SelectedIndexChanged="FilePicker_Changed"/>
                <Button Grid.Column="2" x:Name="btnDelete" Text="🗑" FontSize="14"
                        BackgroundColor="#B71C1C" TextColor="White" Padding="8,0"
                        HeightRequest="36" CornerRadius="8" Margin="6,0,0,0"
                        Clicked="BtnDelete_Clicked"/>
            </Grid>
            <Grid ColumnDefinitions="Auto,*" x:Name="setPickerRow">
                <Label Grid.Column="0" Text="Set:" FontSize="13" FontAttributes="Bold"
                       TextColor="#374151" VerticalOptions="Center" Margin="0,0,8,0"/>
                <Picker Grid.Column="1" x:Name="setPicker" FontSize="13"
                        BackgroundColor="#F8F9FA" HeightRequest="36"
                        SelectedIndexChanged="SetPicker_Changed"/>
            </Grid>
            <Label x:Name="lblGameInfo" Text="" FontSize="12" TextColor="#6B7A90"/>
        </VerticalStackLayout>

        <!-- Row 2: No files message -->
        <Label Grid.Row="2" x:Name="lblNoFiles"
               Text="No saved favorites yet.&#10;Use More → Export Sets → Save to MyFavorite to create one."
               FontSize="13" TextColor="#9CA3AF" HorizontalOptions="Center"
               HorizontalTextAlignment="Center" Margin="20,20" IsVisible="False"/>

        <!-- Row 3: Entry grid -->
        <ScrollView Grid.Row="3" BackgroundColor="#F0F4F8">
            <VerticalStackLayout x:Name="rowsContainer" Padding="10,8" Spacing="5"/>
        </ScrollView>

        <!-- Row 4: Buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,*" ColumnSpacing="6"
              Padding="10,8" BackgroundColor="#1E2733" x:Name="btnRow">
            <Button Grid.Column="0" Text="SAVE FILE" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#2E7D32" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnSaveFile_Clicked"/>
            <Button Grid.Column="1" Text="LOAD TO GAME" FontSize="11" FontAttributes="Bold"
                    BackgroundColor="#1565C0" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnLoadToGame_Clicked"/>
            <Button Grid.Column="2" Text="CLEAR ROWS" FontSize="11"
                    BackgroundColor="#FF7043" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnClearRows_Clicked"/>
        </Grid>

    </Grid>
</ContentPage>
