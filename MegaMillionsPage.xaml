<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.MegaMillionsPage"
             Title="Mega Millions"
             Shell.NavBarIsVisible="False"
             ios:Page.UseSafeArea="true"
             BackgroundColor="#1E2733">

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,1">
        <Grid.GestureRecognizers>
            <PanGestureRecognizer PanUpdated="OnPagePan"/>
        </Grid.GestureRecognizers>

        <!-- Row 0: Nav header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="14,10"
              ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" x:Name="btnBack" Text="← PB" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#C62828" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnGoBack_Clicked"/>
            <Label Grid.Column="1" Text="Mega Millions" TextColor="White" FontSize="14"
                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="⌂" FontSize="14" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnGoHome_Clicked" Margin="0,0,6,0"/>
            <Button Grid.Column="3" Text="D3 →" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#1565C0" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnGoD3_Clicked"/>
        </Grid>

        <!-- Row 5: Status bar -->
        <Label Grid.Row="5" x:Name="lblStatus"
               Text="Ready"
               BackgroundColor="#1E2733" TextColor="#8B9DC3"
               FontSize="12" Padding="14,5" LineBreakMode="TailTruncation">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="StatusBar_Tapped"/>
            </Label.GestureRecognizers>
        </Label>

        <!-- Hidden WebView -->
        <WebView x:Name="fetchView" Grid.Row="6" HeightRequest="1" WidthRequest="1"
                 Opacity="0" InputTransparent="True"/>

        <!-- Row 1: Draw banner card -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0"
                StrokeShape="RoundRectangle 0" Margin="0">
            <VerticalStackLayout Padding="14,10" Spacing="6">
                <DatePicker x:Name="drawDatePicker" FontSize="13" TextColor="#374151"
                            Format="ddd MMM d, yyyy" HeightRequest="44"
                            DateSelected="DrawDatePicker_DateSelected"/>
                <Label x:Name="lblDrawDate" Text="Fetching latest draw..."
                       FontSize="12" TextColor="#6B7A90" HorizontalOptions="Center"/>
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Border x:Name="W1" BackgroundColor="#F57F17" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblW1" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W2" BackgroundColor="#F57F17" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblW2" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W3" BackgroundColor="#F57F17" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblW3" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W4" BackgroundColor="#F57F17" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblW4" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W5" BackgroundColor="#F57F17" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblW5" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="MB" FontSize="12" TextColor="#9CA3AF" VerticalOptions="Center" FontAttributes="Bold"/>
                    <Border x:Name="WMB" BackgroundColor="#1565C0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 10" WidthRequest="46" HeightRequest="46">
                        <Label x:Name="lblWMB" Text="?" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <ActivityIndicator x:Name="spinner" IsRunning="False" IsVisible="False"
                                       Color="#F57F17" WidthRequest="28" HeightRequest="28"
                                       VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Row 2: Saved Numbers picker -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="12,6"
              ColumnDefinitions="Auto,*">
            <BoxView Grid.Column="0" BackgroundColor="#F57F17" WidthRequest="4" VerticalOptions="Fill" Margin="0,4,10,4"/>
            <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Label Grid.Column="0" Text="Saved Numbers" FontSize="13" FontAttributes="Bold"
                       TextColor="#374151" VerticalOptions="Center" Margin="0,0,8,0"/>
                <Picker Grid.Column="1" x:Name="slotPicker" FontSize="13"
                        BackgroundColor="#F8F9FA" HeightRequest="36"
                        SelectedIndexChanged="SlotPicker_Changed"/>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center"
                                     VerticalOptions="Center" Spacing="0" Margin="6,0,2,0">
                    <Label Text="Excl" FontSize="9" TextColor="#666" HorizontalOptions="Center"/>
                    <CheckBox x:Name="chkExcl" Color="#F57F17" HorizontalOptions="Center"
                              CheckedChanged="ChkExcl_CheckedChanged" Margin="0,-4,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Row 3: 10 number rows -->
        <ScrollView Grid.Row="3" BackgroundColor="#F0F4F8">
            <VerticalStackLayout x:Name="rowsContainer" Padding="10,8" Spacing="5"/>
        </ScrollView>

        <!-- Row 4: Bottom buttons -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,*,*,*,Auto,Auto" ColumnSpacing="6"
              Padding="10,8" BackgroundColor="#1E2733">
            <Button Grid.Column="0" Text="CHECK" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#F9A825" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnCheck_Clicked"/>
            <Button Grid.Column="1" Text="CLEAR" FontSize="12"
                    BackgroundColor="#FF7043" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnClearAll_Clicked"/>
            <Button Grid.Column="2" Text="REFRESH" FontSize="12"
                    BackgroundColor="#F57F17" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnRefresh_Clicked"/>
            <Button Grid.Column="3" Text="SAVE" FontSize="12"
                    BackgroundColor="#2E7D32" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnSave_Clicked"/>
            <Button Grid.Column="4" Text="CLR SETS" FontSize="11"
                    BackgroundColor="#E65100" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnClearSets_Clicked"/>
            <Button Grid.Column="5" Text="🎲 QP" FontSize="11"
                    BackgroundColor="#1565C0" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="10,0" Clicked="BtnQuickPick_Clicked"/>
            <Button Grid.Column="6" x:Name="btnVoice" Text="🎤" FontSize="18"
                    BackgroundColor="#0277BD" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="10,0" Clicked="BtnVoice_Clicked"/>
        </Grid>

    </Grid>

</ContentPage>
