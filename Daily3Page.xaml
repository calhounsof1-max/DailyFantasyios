<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.Daily3Page"
             Title="Daily 3 Checker"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E2733"
             ios:Page.UseSafeArea="true">

    <Grid BackgroundColor="#F0F4F8" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,1">
        <Grid.GestureRecognizers>
            <PanGestureRecognizer PanUpdated="OnPagePan"/>
        </Grid.GestureRecognizers>

        <!-- Row 0: Nav header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="8,6"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto">
            <Button Grid.Column="0" x:Name="btnBack" Text="← PB" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#C62828" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnGoBack_Clicked"/>
            <Label Grid.Column="1" Text="Daily 3" TextColor="White" FontSize="13"
                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="Games ▾" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnGames_Clicked" Margin="0,0,4,0"/>
            <Button Grid.Column="3" Text="⌂" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#2D3D50" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnGoHome_Clicked" Margin="0,0,4,0"/>
            <Button Grid.Column="4" Text="D4 →" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#00695C" TextColor="White" Padding="6,0"
                    HeightRequest="28" CornerRadius="14" Clicked="BtnGoD4_Clicked"/>
        </Grid>

        <!-- Row 6: Status bar -->
        <Label Grid.Row="6" x:Name="lblStatus"
               Text="Ready"
               BackgroundColor="#1E2733" TextColor="#8B9DC3"
               FontSize="9" Padding="10,3" LineBreakMode="TailTruncation">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="StatusBar_Tapped"/>
            </Label.GestureRecognizers>
        </Label>

        <!-- Hidden WebView -->
        <WebView x:Name="fetchView" Grid.Row="7" HeightRequest="1" WidthRequest="1"
                 Opacity="0" InputTransparent="True"/>

        <!-- Row 1: Draw banner card -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0"
                StrokeShape="RoundRectangle 0" Margin="0">
            <VerticalStackLayout Padding="10,6" Spacing="4">
                <DatePicker x:Name="drawDatePicker" FontSize="10" TextColor="#374151"
                            Format="ddd MMM d, yyyy" HeightRequest="28"
                            DateSelected="DrawDatePicker_DateSelected"/>
                <Label x:Name="lblDrawDate" Text="Fetching Daily 3 draw..."
                       FontSize="10" TextColor="#6B7A90" HorizontalOptions="Center"/>

                <!-- Midday row -->
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="Midday" FontSize="9" TextColor="#9CA3AF"
                           VerticalOptions="Center" WidthRequest="44" HorizontalTextAlignment="End"/>
                    <Border x:Name="W1" BackgroundColor="#1565C0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblW1" Text="?" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W2" BackgroundColor="#1565C0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblW2" Text="?" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="W3" BackgroundColor="#1565C0" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblW3" Text="?" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <ActivityIndicator x:Name="spinner" IsRunning="False" IsVisible="False"
                                       Color="#1565C0" WidthRequest="20" HeightRequest="20"
                                       VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Evening row -->
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="Evening" FontSize="9" TextColor="#9CA3AF"
                           VerticalOptions="Center" WidthRequest="44" HorizontalTextAlignment="End"/>
                    <Border x:Name="E1" BackgroundColor="#0D47A1" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblE1" Text="-" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="E2" BackgroundColor="#0D47A1" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblE2" Text="-" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Border x:Name="E3" BackgroundColor="#0D47A1" StrokeThickness="0"
                            StrokeShape="RoundRectangle 8" WidthRequest="38" HeightRequest="38">
                        <Label x:Name="lblE3" Text="-" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Row 2: From highlight control + All-rows bet type -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10,4"
              ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
            <BoxView Grid.Column="0" BackgroundColor="#1565C0" WidthRequest="3"
                     VerticalOptions="Fill" Margin="0,3,8,3"/>
            <Label Grid.Column="1" Text="From:" FontSize="11" TextColor="#374151"
                   VerticalOptions="Center" FontAttributes="Bold"/>
            <Entry Grid.Column="2" x:Name="fromEntry" Keyboard="Numeric" WidthRequest="44"
                   HeightRequest="22" FontSize="11" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" TextColor="Black" BackgroundColor="#F8F9FA"
                   TextChanged="FromEntry_TextChanged"/>
            <Label Grid.Column="3" Text=" rows" FontSize="10"
                   TextColor="#9CA3AF" VerticalOptions="Center"/>
            <Label Grid.Column="4" Text="" />
            <!-- All-rows bet type picker -->
            <Grid Grid.Column="5" ColumnDefinitions="Auto,Auto" ColumnSpacing="3"
                  VerticalOptions="Center">
                <Label Grid.Column="0" Text="All:" FontSize="9" TextColor="#546E7A"
                       VerticalOptions="Center"/>
                <Picker Grid.Column="1" x:Name="allBetPicker" FontSize="9"
                        WidthRequest="64" HeightRequest="22" BackgroundColor="#F8F9FA"
                        SelectedIndexChanged="AllBetPicker_Changed"/>
            </Grid>
        </Grid>

        <!-- Row 3: Saved Numbers picker -->
        <Grid Grid.Row="3" BackgroundColor="White" Padding="10,4"
              ColumnDefinitions="Auto,Auto,*,Auto">
            <BoxView Grid.Column="0" BackgroundColor="#1565C0" WidthRequest="3"
                     VerticalOptions="Fill" Margin="0,3,8,3"/>
            <Label Grid.Column="1" Text="Saved Numbers" FontSize="11" FontAttributes="Bold"
                   TextColor="#374151" VerticalOptions="Center" Margin="0,0,6,0"/>
            <Picker Grid.Column="2" x:Name="slotPicker" FontSize="10"
                    BackgroundColor="#F8F9FA" HeightRequest="22"
                    SelectedIndexChanged="SlotPicker_Changed"/>
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center"
                                 VerticalOptions="Center" Spacing="0" Margin="4,0,2,0">
                <Label Text="Excl" FontSize="9" TextColor="#666" HorizontalOptions="Center"/>
                <CheckBox x:Name="chkExcl" Color="#C62828" HorizontalOptions="Center"
                          CheckedChanged="ChkExcl_CheckedChanged" Margin="0,-4,0,0"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Row 4: 10 number rows -->
        <ScrollView Grid.Row="4" BackgroundColor="#F0F4F8">
            <VerticalStackLayout x:Name="rowsContainer" Padding="8,6" Spacing="4"/>
        </ScrollView>

        <!-- Row 5: Bottom buttons -->
        <Grid Grid.Row="5" ColumnDefinitions="*,*,*,*,*,Auto,Auto" ColumnSpacing="4"
              Padding="8,5" BackgroundColor="#1E2733">
            <Button Grid.Column="0" Text="CHECK" FontSize="9" FontAttributes="Bold"
                    BackgroundColor="#F9A825" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnCheck_Clicked"/>
            <Button Grid.Column="1" Text="CLEAR" FontSize="9"
                    BackgroundColor="#FF7043" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnClearAll_Clicked"/>
            <Button Grid.Column="2" Text="REFRESH" FontSize="9"
                    BackgroundColor="#1565C0" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnRefresh_Clicked"/>
            <Button Grid.Column="3" Text="SAVE" FontSize="9"
                    BackgroundColor="#2E7D32" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnSave_Clicked"/>
            <Button Grid.Column="4" Text="CLR SETS" FontSize="9"
                    BackgroundColor="#B71C1C" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="3,0" Clicked="BtnClearSets_Clicked"/>
            <Button Grid.Column="5" Text="🎲 QP" FontSize="9"
                    BackgroundColor="#6A1B9A" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="6,0" Clicked="BtnQuickPick_Clicked"/>
            <Button Grid.Column="6" x:Name="btnVoice" Text="🎤" FontSize="12"
                    BackgroundColor="#0277BD" TextColor="White" HeightRequest="28"
                    CornerRadius="14" Padding="6,0" Clicked="BtnVoice_Clicked"/>
        </Grid>

    </Grid>

</ContentPage>
