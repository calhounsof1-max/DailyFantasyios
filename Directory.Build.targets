<Project>
  <!-- Exclude stale generated files that may remain in the OneDrive obj folder -->
  <ItemGroup>
    <Compile Remove="obj\**\*.cs" />
  </ItemGroup>

  <!-- On Windows (no Mac), disable trimming/AOT to allow building without a Mac connection -->
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows')) AND $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">
    <PublishTrimmed>false</PublishTrimmed>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <EnableSingleFileAnalyzer>false</EnableSingleFileAnalyzer>
    <NoWarn>$(NoWarn);NETSDK1195</NoWarn>
  </PropertyGroup>
</Project>
