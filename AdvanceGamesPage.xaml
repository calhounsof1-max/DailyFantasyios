<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.AdvanceGamesPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="◀" FontSize="16" BackgroundColor="Transparent"
                    TextColor="White" Padding="4,0" HeightRequest="34" WidthRequest="40"
                    Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="Games Expiration" TextColor="White"
                   FontSize="15" FontAttributes="Bold"
                   VerticalOptions="Center" HorizontalOptions="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="_container" Spacing="12" Padding="14,16,14,24"/>
        </ScrollView>

    </Grid>
</ContentPage>
