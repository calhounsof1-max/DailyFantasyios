<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailyFantasyMAUI.DailyDerbyPage"
             Title="Daily Derby"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,1">
        <Grid.GestureRecognizers>
            <PanGestureRecognizer PanUpdated="OnPagePan"/>
        </Grid.GestureRecognizers>

        <!-- Row 0: Nav header -->
        <Grid Grid.Row="0" BackgroundColor="#1E2733" Padding="14,10"
              ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" x:Name="btnBack" Text="← D4" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#00695C" TextColor="White" Padding="10,0"
                    HeightRequest="34" CornerRadius="17" Clicked="BtnBack_Clicked"/>
            <Label Grid.Column="1" Text="Daily Derby" TextColor="White" FontSize="14"
                   FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- Row 6: Status bar -->
        <Label Grid.Row="6" x:Name="lblStatus" Text="Ready"
               BackgroundColor="#1E2733" TextColor="#8B9DC3"
               FontSize="12" Padding="14,5" LineBreakMode="TailTruncation">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="StatusBar_Tapped"/>
            </Label.GestureRecognizers>
        </Label>

        <!-- Hidden WebView -->
        <WebView x:Name="fetchView" Grid.Row="7" HeightRequest="1" WidthRequest="1"
                 Opacity="0" InputTransparent="True"/>

        <!-- Row 1: Draw banner card -->
        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0"
                StrokeShape="RoundRectangle 0" Margin="0">
            <VerticalStackLayout Padding="14,10" Spacing="6">
                <DatePicker x:Name="drawDatePicker" FontSize="13" TextColor="#374151"
                            Format="ddd MMM d, yyyy" HeightRequest="44"
                            DateSelected="DrawDatePicker_DateSelected"/>
                <Label x:Name="lblDrawDate" Text="Fetching Daily Derby draw..."
                       FontSize="12" TextColor="#6B7A90" HorizontalOptions="Center"/>

                <!-- 3 horse tiles + race time -->
                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                    <!-- 1st place -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="1st" FontSize="10" TextColor="#9CA3AF"
                               HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border x:Name="WH1" BackgroundColor="#5D4037" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" WidthRequest="72" HeightRequest="56">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label x:Name="lblWH1" Text="?" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label x:Name="lblWN1" Text="" FontSize="8" TextColor="#FFCCBC"
                                       HorizontalOptions="Center" LineBreakMode="TailTruncation"
                                       Padding="2,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                    <!-- 2nd place -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="2nd" FontSize="10" TextColor="#9CA3AF"
                               HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border x:Name="WH2" BackgroundColor="#5D4037" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" WidthRequest="72" HeightRequest="56">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label x:Name="lblWH2" Text="?" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label x:Name="lblWN2" Text="" FontSize="8" TextColor="#FFCCBC"
                                       HorizontalOptions="Center" LineBreakMode="TailTruncation"
                                       Padding="2,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                    <!-- 3rd place -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="3rd" FontSize="10" TextColor="#9CA3AF"
                               HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border x:Name="WH3" BackgroundColor="#5D4037" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" WidthRequest="72" HeightRequest="56">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                                <Label x:Name="lblWH3" Text="?" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label x:Name="lblWN3" Text="" FontSize="8" TextColor="#FFCCBC"
                                       HorizontalOptions="Center" LineBreakMode="TailTruncation"
                                       Padding="2,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                    <!-- Race time -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="⏱ Time" FontSize="10" TextColor="#9CA3AF"
                               HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border BackgroundColor="#3E2723" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" HeightRequest="56" Padding="10,0">
                            <Label x:Name="lblWTime" Text="?:??.??" FontSize="16" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>
                    <ActivityIndicator x:Name="spinner" IsRunning="False" IsVisible="False"
                                       Color="#5D4037" WidthRequest="28" HeightRequest="28"
                                       VerticalOptions="End"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Row 2: From highlight control -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="12,5"
              ColumnDefinitions="Auto,Auto,Auto,*">
            <BoxView Grid.Column="0" BackgroundColor="#5D4037" WidthRequest="4"
                     VerticalOptions="Fill" Margin="0,4,10,4"/>
            <Label Grid.Column="1" Text="From:" FontSize="13" TextColor="#374151"
                   VerticalOptions="Center" FontAttributes="Bold"/>
            <Entry Grid.Column="2" x:Name="fromEntry" Keyboard="Numeric" WidthRequest="56"
                   HeightRequest="34" FontSize="15" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" TextColor="Black" BackgroundColor="#F8F9FA"
                   TextChanged="FromEntry_TextChanged"/>
            <Label Grid.Column="3" Text=" rows highlighted" FontSize="12"
                   TextColor="#9CA3AF" VerticalOptions="Center"/>
        </Grid>

        <!-- Row 3: Saved Numbers picker -->
        <Grid Grid.Row="3" BackgroundColor="White" Padding="12,6"
              ColumnDefinitions="Auto,Auto,*">
            <BoxView Grid.Column="0" BackgroundColor="#5D4037" WidthRequest="4"
                     VerticalOptions="Fill" Margin="0,4,10,4"/>
            <Label Grid.Column="1" Text="Saved Numbers" FontSize="13" FontAttributes="Bold"
                   TextColor="#374151" VerticalOptions="Center" Margin="0,0,8,0"/>
            <Picker Grid.Column="2" x:Name="slotPicker" FontSize="13"
                    BackgroundColor="#F8F9FA" HeightRequest="36"
                    SelectedIndexChanged="SlotPicker_Changed"/>
        </Grid>

        <!-- Row 4: 10 entry rows -->
        <ScrollView Grid.Row="4" BackgroundColor="#F0F4F8">
            <VerticalStackLayout x:Name="rowsContainer" Padding="10,8" Spacing="5"/>
        </ScrollView>

        <!-- Row 5: Bottom buttons -->
        <Grid Grid.Row="5" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6"
              Padding="10,8" BackgroundColor="#1E2733">
            <Button Grid.Column="0" Text="CHECK" FontSize="12" FontAttributes="Bold"
                    BackgroundColor="#F9A825" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnCheck_Clicked"/>
            <Button Grid.Column="1" Text="CLEAR" FontSize="12"
                    BackgroundColor="#FF7043" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnClearAll_Clicked"/>
            <Button Grid.Column="2" Text="REFRESH" FontSize="12"
                    BackgroundColor="#5D4037" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnRefresh_Clicked"/>
            <Button Grid.Column="3" Text="SAVE" FontSize="12"
                    BackgroundColor="#2E7D32" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnSave_Clicked"/>
            <Button Grid.Column="4" Text="CLR SETS" FontSize="11"
                    BackgroundColor="#B71C1C" TextColor="White" HeightRequest="42"
                    CornerRadius="21" Padding="4,0" Clicked="BtnClearSets_Clicked"/>
        </Grid>
    </Grid>

</ContentPage>
